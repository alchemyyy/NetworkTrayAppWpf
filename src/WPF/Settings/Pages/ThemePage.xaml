<UserControl
    x:Class="NetworkTrayAppWPF.WPF.Settings.Pages.ThemePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:loc="clr-namespace:NetworkTrayAppWPF.Localization"
    xmlns:local="clr-namespace:NetworkTrayAppWPF.WPF"
    xmlns:utils="clr-namespace:NetworkTrayAppWPF.WPF.Settings.Utils"
    xmlns:utils1="clr-namespace:NetworkTrayAppWPF.WPF.Utils"
    mc:Ignorable="d"
    d:DesignWidth="660"
    d:DesignHeight="594"
    d:Background="#1F1F1F"
    utils1:SettingsKeyboardNavigation.IsContentSection="True">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{loc:Loc Settings_Theme_SectionHeader}"/>

        <TextBlock Text="{loc:Loc Settings_Theme_ContextMenu_Header}"
                   Style="{StaticResource SettingTitleStyle}"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_FontSize_Title}"
                               Description="{loc:Loc Settings_Theme_FontSize_Description}">
            <utils:SettingsCard.Control>
                <local:NumericSpinner Width="100" VerticalAlignment="Center"
                                      x:Name="ContextMenuFontSizeBox"
                                      Minimum="8" Maximum="48"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Theme_Appearance_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_ThemeStyle_Title}"
                               Description="{loc:Loc Settings_Theme_ThemeStyle_Description}">
            <utils:SettingsCard.Control>
                <ComboBox x:Name="ThemeModeCombo"
                          Style="{StaticResource SettingsComboBoxStyle}"
                          VerticalAlignment="Center"
                          Tag="ThemeMode" SelectionChanged="EnumCombo_Changed">
                    <ComboBoxItem Tag="System" Content="{loc:Loc Settings_Theme_ThemeStyle_System}"/>
                    <ComboBoxItem Tag="Light" Content="{loc:Loc Settings_Theme_ThemeStyle_Light}"/>
                    <ComboBoxItem Tag="Dark" Content="{loc:Loc Settings_Theme_ThemeStyle_Dark}"/>
                </ComboBox>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_TextColor_Title}"
                               Description="{loc:Loc Settings_Theme_TextColor_Description}">
            <utils:SettingsCard.Control>
                <StackPanel Style="{StaticResource SettingsCardControlPanel}">
                    <Button x:Name="TextColorLightSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Text|Light" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Theme_TextColor_LightTooltip}"/>
                    <Button x:Name="TextColorDarkSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Text|Dark" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Theme_TextColor_DarkTooltip}"/>
                    <Button Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_Theme_Reset}"
                            Tag="Text" Click="ColorReset_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_BackgroundColor_Title}"
                               Description="{loc:Loc Settings_Theme_BackgroundColor_Description}">
            <utils:SettingsCard.Control>
                <StackPanel Style="{StaticResource SettingsCardControlPanel}">
                    <Button x:Name="BackgroundColorLightSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Background|Light" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Theme_BackgroundColor_LightTooltip}"/>
                    <Button x:Name="BackgroundColorDarkSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Background|Dark" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Theme_BackgroundColor_DarkTooltip}"/>
                    <Button Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_Theme_Reset}"
                            Tag="Background" Click="ColorReset_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Theme_Flyout_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_RoundedCorners_Title}"
                               Description="{loc:Loc Settings_Theme_RoundedCorners_Description}">
            <utils:SettingsCard.Control>
                <CheckBox x:Name="RoundedCornersToggle"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Tag="EnableRoundedCorners" Checked="BoolToggle_Changed"
                          Unchecked="BoolToggle_Changed"/>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Theme_TrayIcon_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Theme_StaticIconColor_Title}"
                               Description="{loc:Loc Settings_Theme_StaticIconColor_Description}">
            <utils:SettingsCard.Control>
                <StackPanel Style="{StaticResource SettingsCardControlPanel}">
                    <Button x:Name="TrayIconColorLightSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="TrayIcon|Light" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Theme_StaticIconColor_LightTooltip}"/>
                    <Button x:Name="TrayIconColorDarkSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="TrayIcon|Dark" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Theme_StaticIconColor_DarkTooltip}"/>
                    <Button Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_Theme_Reset}"
                            Tag="TrayIcon" Click="ColorReset_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>
    </StackPanel>
</UserControl>
