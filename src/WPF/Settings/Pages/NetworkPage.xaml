<UserControl
    x:Class="NetworkTrayAppWPF.WPF.Settings.Pages.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:loc="clr-namespace:NetworkTrayAppWPF.Localization"
    xmlns:utils="clr-namespace:NetworkTrayAppWPF.WPF.Settings.Utils"
    xmlns:utils1="clr-namespace:NetworkTrayAppWPF.WPF.Utils"
    mc:Ignorable="d"
    d:DesignWidth="660"
    d:DesignHeight="594"
    d:Background="#1F1F1F"
    utils1:SettingsKeyboardNavigation.IsContentSection="True">
    <StackPanel>
        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="{loc:Loc Settings_Network_SectionHeader}"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Network_FlyoutStyle_Title}"
                            Description="{loc:Loc Settings_Network_FlyoutStyle_Description}">
            <utils:SettingsCard.Control>
                <ComboBox x:Name="FlyoutStyleCombo"
                          Style="{StaticResource SettingsComboBoxStyle}"
                          VerticalAlignment="Center"
                          Tag="FlyoutStyle" SelectionChanged="EnumCombo_Changed">
                    <ComboBoxItem Tag="Windows10" Content="{loc:Loc Settings_Network_FlyoutStyle_Windows10}"/>
                    <ComboBoxItem Tag="Windows11" Content="{loc:Loc Settings_Network_FlyoutStyle_Windows11}"/>
                    <ComboBoxItem Tag="QuickSettings" Content="{loc:Loc Settings_Network_FlyoutStyle_QuickSettings}"/>
                    <ComboBoxItem Tag="AvailableNetworks" Content="{loc:Loc Settings_Network_FlyoutStyle_AvailableNetworks}"/>
                    <ComboBoxItem Tag="Settings" Content="{loc:Loc Settings_Network_FlyoutStyle_Settings}"/>
                </ComboBox>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Network_AdapterSettingsStyle_Title}"
                            Description="{loc:Loc Settings_Network_AdapterSettingsStyle_Description}">
            <utils:SettingsCard.Control>
                <ComboBox x:Name="AdapterSettingsStyleCombo"
                          Style="{StaticResource SettingsComboBoxStyle}"
                          VerticalAlignment="Center"
                          Tag="AdapterSettingsStyle" SelectionChanged="EnumCombo_Changed">
                    <ComboBoxItem Tag="Explorer" Content="{loc:Loc Settings_Network_AdapterSettingsStyle_Explorer}"/>
                    <ComboBoxItem Tag="ControlPanel" Content="{loc:Loc Settings_Network_AdapterSettingsStyle_ControlPanel}"/>
                </ComboBox>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <TextBlock Text="{loc:Loc Settings_Network_StateColors_Header}"
                   Style="{StaticResource SubsectionHeaderStyle}"/>
        <TextBlock Style="{StaticResource SettingDescriptionStyle}"
                   Text="{loc:Loc Settings_Network_StateColors_Description}"
                   Margin="0,0,0,8"/>

        <utils:SettingsCard Title="{loc:Loc Settings_Network_ConnectedColor_Title}"
                            Description="{loc:Loc Settings_Network_ConnectedColor_Description}">
            <utils:SettingsCard.Control>
                <StackPanel Style="{StaticResource SettingsCardControlPanel}">
                    <Button x:Name="ConnectedColorLightSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Connected|Light" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Network_ConnectedColor_LightTooltip}"/>
                    <Button x:Name="ConnectedColorDarkSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Connected|Dark" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Network_ConnectedColor_DarkTooltip}"/>
                    <Button Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_Theme_Reset}"
                            Tag="Connected" Click="ColorReset_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Network_NoInternetColor_Title}"
                            Description="{loc:Loc Settings_Network_NoInternetColor_Description}">
            <utils:SettingsCard.Control>
                <StackPanel Style="{StaticResource SettingsCardControlPanel}">
                    <Button x:Name="NoInternetColorLightSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="NoInternet|Light" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Network_NoInternetColor_LightTooltip}"/>
                    <Button x:Name="NoInternetColorDarkSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="NoInternet|Dark" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Network_NoInternetColor_DarkTooltip}"/>
                    <Button Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_Theme_Reset}"
                            Tag="NoInternet" Click="ColorReset_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>

        <utils:SettingsCard Title="{loc:Loc Settings_Network_DisconnectedColor_Title}"
                            Description="{loc:Loc Settings_Network_DisconnectedColor_Description}">
            <utils:SettingsCard.Control>
                <StackPanel Style="{StaticResource SettingsCardControlPanel}">
                    <Button x:Name="DisconnectedColorLightSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Disconnected|Light" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Network_DisconnectedColor_LightTooltip}"/>
                    <Button x:Name="DisconnectedColorDarkSwatch"
                            Style="{StaticResource ColorRowSwatchStyle}"
                            Tag="Disconnected|Dark" Click="ColorSwatch_Click"
                            ToolTip="{loc:Loc Settings_Network_DisconnectedColor_DarkTooltip}"/>
                    <Button Style="{StaticResource SettingsButtonStyle}"
                            Content="{loc:Loc Settings_Theme_Reset}"
                            Tag="Disconnected" Click="ColorReset_Click"/>
                </StackPanel>
            </utils:SettingsCard.Control>
        </utils:SettingsCard>
    </StackPanel>
</UserControl>
